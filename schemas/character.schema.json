{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Character Canon",
  "type": "object",
  "required": ["id", "displayName", "summary", "profile", "glossary", "settings", "timeline", "promptGuidance"],
  "properties": {
    "id": { "type": "string" },
    "displayName": { "type": "string" },
    "catchphrase": { "type": "string" },
    "summary": { "type": "string" },
    "theme": {
      "type": "object",
      "properties": {
        "primary": { "type": "string" },
        "secondary": { "type": "string" },
        "accent": { "type": "string" },
        "paper": { "type": "string" },
        "panel": { "type": "string" },
        "text": { "type": "string" },
        "muted": { "type": "string" }
      }
    },
    "brandAssets": {
      "type": "object",
      "properties": {
        "logo": {
          "type": "object",
          "required": ["source"],
          "properties": {
            "source": { "type": "string" },
            "alt": { "type": "string" }
          }
        },
        "banner": {
          "type": "object",
          "required": ["source"],
          "properties": {
            "source": { "type": "string" },
            "alt": { "type": "string" },
            "logoPlacement": {
              "type": "object",
              "properties": {
                "left": { "type": "number" },
                "top": { "type": "number" },
                "width": { "type": "number" }
              }
            }
          }
        }
      }
    },
    "profile": {
      "type": "object",
      "additionalProperties": { "type": "string" }
    },
    "likes": {
      "type": "array",
      "items": { "type": "string" }
    },
    "links": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["label", "url"],
        "properties": {
          "label": { "type": "string" },
          "url": { "type": "string" },
          "type": { "type": "string" },
          "icon": { "type": "string" },
          "displayUrl": { "type": "string" },
          "description": { "type": "string" }
        }
      }
    },
    "contentLinks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["label", "url"],
        "properties": {
          "label": { "type": "string" },
          "url": { "type": "string" },
          "type": { "type": "string" },
          "icon": { "type": "string" },
          "displayUrl": { "type": "string" },
          "description": { "type": "string" }
        }
      }
    },
    "musicVideoPlayer": {
      "type": "object",
      "required": ["title", "embedUrl"],
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "playlistUrl": { "type": "string" },
        "embedUrl": { "type": "string" },
        "icon": { "type": "string" },
        "trackTitle": { "type": "string" },
        "trackSubtitle": { "type": "string" },
        "orientationOptions": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["key", "label", "aspectRatio"],
            "properties": {
              "key": { "type": "string" },
              "label": { "type": "string" },
              "aspectRatio": { "type": "string" }
            }
          }
        }
      }
    },
    "rights": {
      "type": "object",
      "properties": {
        "holderName": { "type": "string" },
        "holderUrl": { "type": "string" },
        "managedBy": { "type": "string" },
        "managedByUrl": { "type": "string" },
        "contact": { "type": "string" },
        "contactUrl": { "type": "string" },
        "notice": { "type": "string" }
      }
    },
    "fanworkGuidelines": {
      "type": "object",
      "required": ["title", "summary", "status", "sections"],
      "properties": {
        "title": { "type": "string" },
        "summary": { "type": "string" },
        "status": { "type": "string" },
        "contact": { "type": "string" },
        "revisionHistory": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["date", "summary"],
            "properties": {
              "date": { "type": "string" },
              "summary": { "type": "string" }
            }
          }
        },
        "sections": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["title", "items"],
            "properties": {
              "title": { "type": "string" },
              "items": {
                "type": "array",
                "items": { "type": "string" }
              }
            }
          }
        }
      }
    },
    "glossary": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["term", "definition"],
        "properties": {
          "term": { "type": "string" },
          "definition": { "type": "string" }
        }
      }
    },
    "settings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["title", "body"],
        "properties": {
          "title": { "type": "string" },
          "body": { "type": "string" },
          "status": { "type": "string" }
        }
      }
    },
    "sideFlavors": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["title", "body"],
        "properties": {
          "title": { "type": "string" },
          "body": { "type": "string" },
          "status": { "type": "string" }
        }
      }
    },
    "visualReferences": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["label", "path"],
        "properties": {
          "label": { "type": "string" },
          "path": { "type": "string" },
          "type": { "type": "string" },
          "description": { "type": "string" }
        }
      }
    },
    "timeline": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["date", "event"],
        "properties": {
          "date": { "type": "string" },
          "event": { "type": "string" },
          "detail": { "type": "string" },
          "image": {
            "oneOf": [
              { "type": "string" },
              {
                "type": "object",
                "required": ["path"],
                "properties": {
                  "path": { "type": "string" },
                  "alt": { "type": "string" },
                  "caption": { "type": "string" }
                }
              }
            ]
          },
          "timelineType": {
            "type": "string",
            "enum": ["fictional", "real"]
          }
        }
      }
    },
    "promptGuidance": {
      "type": "object",
      "required": ["agent", "image", "video"],
      "properties": {
        "agent": { "type": "array", "items": { "type": "string" } },
        "t2t": { "type": "array", "items": { "type": "string" } },
        "image": { "type": "array", "items": { "type": "string" } },
        "video": { "type": "array", "items": { "type": "string" } }
      }
    },
    "sources": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["label"],
        "properties": {
          "label": { "type": "string" },
          "url": { "type": "string" },
          "note": { "type": "string" }
        }
      }
    }
  }
}
